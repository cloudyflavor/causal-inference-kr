   'n_get': int((df['action'] == 2).sum()),\n        'n_post': int((df['action'] == 3).sum()),\n        'n_put': int((df['action'] == 4).sum()),\n        'n_actions': len(df),\n        'n_days': int(df['timestamp'].dt.date.nunique()),\n    }\n\nif CACHE.exists():\n    data = pd.read_parquet(CACHE)\nelse:\n    with open(BASE / 'info.json', encoding='utf-8') as f:\n        info = json.load(f)\n    records = []\n    for item in info:\n        fp = BASE / item['X']\n        if not fp.exists():\n            continue\n        feats = extract_features(fp)\n        if feats is None:\n            continue\n        feats.update({'T': item['T'], 'Y0': item['Y'][0], 'Y1': item['Y'][1], 'Y2': item['Y'][2]})\n        records.append(feats)\n    data = pd.DataFrame(records)\n    data.to_parquet(CACHE, index=False)","key":"bfCNxGCNNV"},{"type":"outputs","id":"ilPY6xPNIlk7HU1j_9IIr","children":[],"key":"pg7WUb4cPR"}],"key":"h9M7G4glzU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"1단계 — ATE: 전체 평균 처치 효과","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"RIdV3MtwwG"}],"identifier":"id-1-ate","label":"1단계 — ATE: 전체 평균 처치 효과","html_id":"id-1-ate","implicit":true,"key":"t9wbb3oy4m"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"처치 전후 재방문율을 비교합니다.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pyUSJ5AMku"}],"key":"lfyYdkohoQ"},{"type":"code","lang":"","value":"ATE = E[Y | T=1] - E[Y | T=0]","position":{"start":{"line":5,"column":1},"end":{"line":7,"column":1}},"key":"eO9Rmf40uz"}],"key":"ViSKc3o38E"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rate_t0 = data.loc[data['T'] == 0, 'Y2'].mean()\nrate_t1 = data.loc[data['T'] == 1, 'Y2'].mean()\nate = rate_t1 - rate_t0\n\nprint(f'T=0 재방문율: {rate_t0:.1%}')\nprint(f'T=1 재방문율: {rate_t1:.1%}')\nprint(f'ATE: {ate:+.1%}')\n\nfig, ax = plt.subplots(figsize=(5, 4))\nax.bar(['처치 전 (T=0)', '처치 후 (T=1)'], [rate_t0, rate_t1],\n       color=['#BBBBBB', '#4477AA'], width=0.4)\nax.yaxis.set_major_formatter(mtick.PercentFormatter(1.0))\nax.set_ylim(0, max(rate_t0, rate_t1) * 1.3)\nfor i, v in enumerate([rate_t0, rate_t1]):\n    ax.text(i, v + 0.008, f'{v:.1%}', ha='center', va='bottom')\nax.set_title(f'ATE = {ate:+.1%}')\nplt.tight_layout()\nplt.show()","key":"T6qitVb446"},{"type":"outputs","id":"ydKuE2zth-TfGZYZFBGuC","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"T=0 재방문율: 55.7%\nT=1 재방문율: 57.9%\nATE: +2.2%\n"},"children":[],"key":"z5Pvi1iUUv"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"51bf4857fd2e6437b8dda897825e2b1b","path":"/causal-inference-kr/build/51bf4857fd2e6437b8dda897825e2b1b.png"},"text/plain":{"content":"<Figure size 500x400 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"Ltf7oifcZF"}],"key":"Bbnm3mVYb8"}],"key":"XPrxKDBHlK"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2단계 — HTE: 효과는 모든 유저에게 같았을까?","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"seyTNftLwQ"}],"identifier":"id-2-hte","label":"2단계 — HTE: 효과는 모든 유저에게 같았을까?","html_id":"id-2-hte","implicit":true,"key":"lGSnQds6yB"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ATE는 전체 평균입니다. 처치 효과가 유저마다 다르다면 평균이 그 차이를 숨깁니다.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Fma6S8QP0M"}],"key":"Ob95IMhXdo"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"유저를 특성에 따라 그룹으로 나눠 처치 효과를 비교하는 것을 sub-group analysis라고 합니다.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"VS3oBBABeP"}],"key":"PhSxip6xdO"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"접속 횟수 중앙값을 기준으로 라이트/코어 유저로 나눠 각 그룹의 처치 효과를 비교합니다.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"zN6GBx7p6y"}],"key":"CdpMvy5uaE"}],"key":"EI03Wl5IpU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"median_logins = data['n_logins'].median()\ngroups = {\n    f'라이트 (< {int(median_logins)}회)': data[data['n_logins'] < median_logins],\n    f'코어 (≥ {int(median_logins)}회)': data[data['n_logins'] >= median_logins],\n}\n\nstats = {\n    label: {'T0': g[g['T'] == 0]['Y2'].mean(), 'T1': g[g['T'] == 1]['Y2'].mean()}\n    for label, g in groups.items()\n}\nfor s in stats.values():\n    s['effect'] = s['T1'] - s['T0']\n\nCOLORS = ['#4477AA', '#EE6677']\nfig, axes = plt.subplots(1, 2, figsize=(11, 4))\n\nax = axes[0]\nfor i, (label, s) in enumerate(stats.items()):\n    ax.plot([0, 1], [s['T0'], s['T1']], color=COLORS[i], marker='o',\n            linewidth=2, markersize=7, label=label)\n    ax.text(-0.06, s['T0'], f'{s[\"T0\"]:.1%}', ha='right', va='center', color=COLORS[i])\n    ax.text(1.06, s['T1'], f'{s[\"T1\"]:.1%}', ha='left', va='center', color=COLORS[i])\nax.set_xticks([0, 1])\nax.set_xticklabels(['처치 전 (T=0)', '처치 후 (T=1)'])\nax.set_xlim(-0.35, 1.35)\nax.yaxis.set_major_formatter(mtick.PercentFormatter(1.0))\nax.set_title('처치 전후 재방문율')\nax.legend(loc='upper left')\n\nax = axes[1]\nlabels = list(stats.keys())\neffects = [s['effect'] for s in stats.values()]\nax.bar(labels, effects, color=COLORS, width=0.35)\nax.axhline(ate, color='#888888', linestyle='--', linewidth=1.2, label=f'전체 ATE ({ate:+.1%})')\nax.axhline(0, color='black', linewidth=0.8)\nax.yaxis.set_major_formatter(mtick.PercentFormatter(1.0))\nax.set_title('그룹별 처치 효과')\nfor i, v in enumerate(effects):\n    offset, va = (0.003, 'bottom') if v >= 0 else (-0.003, 'top')\n    ax.text(i, v + offset, f'{v:+.1%}', ha='center', va=va)\nax.legend()\n\nplt.tight_layout()\nplt.show()","key":"RMXRImezEb"},{"type":"outputs","id":"lL0zbvf6k-YHHheZlLpq-","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"8ef6af6f3d65453a0476f23eb6021b64","path":"/causal-inference-kr/build/8ef6af6f3d65453a0476f23eb6021b64.png"},"text/plain":{"content":"<Figure size 1100x400 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"FD6SfXTp3E"}],"key":"VcU9aMeqfz"}],"key":"EAlINHEGdu"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3단계 — CATE: HTE를 연속적으로 수치화하기","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uBlyPseQVT"}],"identifier":"id-3-cate-hte","label":"3단계 — CATE: HTE를 연속적으로 수치화하기","html_id":"id-3-cate-hte","implicit":true,"key":"Y30VHKP0OM"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"그룹 비교로는 \"두 그룹이 다르다\"는 것만 알 수 있습니다.\n상호작용 모델을 사용하면 특성 X에 따라 처치 효과가 어떻게 달라지는지 연속적으로 추정할 수 있습니다.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QCS31sQ16j"}],"key":"enx1z7kweZ"},{"type":"code","lang":"","value":"Y = β₀ + β₁T + β₂X + β₃(T×X) + ε\n\nCATE(X) = ∂Ŷ/∂T = β₁ + β₃·X","position":{"start":{"line":6,"column":1},"end":{"line":10,"column":1}},"key":"DIiQq36KzH"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"β₁은 X와 무관한 기본 처치 효과이고, β₃는 X가 1 증가할 때 처치 효과가 변하는 크기입니다.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"MJRjZDoX3K"}],"key":"qZ4yqMq6d1"},{"type":"table","position":{"start":{"line":14,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"β₃의 부호","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"cwRty3GpiX"}],"key":"oRcKWTcw8y"},{"type":"tableCell","header":true,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"의미","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"oXm9ImjoPt"}],"key":"rflYh8PXEJ"}],"key":"keiVk3hSE2"},{"type":"tableRow","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"β₃ > 0","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"u6X3JxmyFS"}],"key":"TCxOflxjUh"},{"type":"tableCell","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"X가 클수록 처치 효과 증가","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"Uh1EiA1eVu"}],"key":"do3c89wNYJ"}],"key":"BTT6nwg68j"},{"type":"tableRow","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"β₃ < 0","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"uNmgBWz4TT"}],"key":"uobfxaQEza"},{"type":"tableCell","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"X가 클수록 처치 효과 감소","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"A9Fmgtmr4L"}],"key":"NLTRGj02DO"}],"key":"ZOqvesUq9X"},{"type":"tableRow","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"tableCell","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"β₃ ≈ 0","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"QmWR4JWb2l"}],"key":"W6B8YI2TZb"},{"type":"tableCell","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"HTE 없음 — ATE로 충분","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"bhtpA3opCd"}],"key":"xHINtzssIm"}],"key":"UZxZikl7bv"}],"key":"yzFE49I0iX"}],"key":"Nfg07vrz4O"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from numpy.linalg import lstsq\n\nX_var = 'n_logins'\nmodel_data = data[['T', X_var, 'Y2']].dropna().copy()\nmodel_data['T_x_X'] = model_data['T'] * model_data[X_var]\n\nX_mat = np.column_stack([\n    np.ones(len(model_data)), model_data['T'], model_data[X_var], model_data['T_x_X']\n])\ncoef, _, _, _ = lstsq(X_mat, model_data['Y2'].values, rcond=None)\nbeta0, beta_T, beta_X, beta_TX = coef\n\nprint(f'β₁ (기본 처치 효과): {beta_T:+.4f}')\nprint(f'β₃ (접속 횟수당 효과 변화): {beta_TX:+.6f}')\nprint()\n\nfor pct, label in [(0.05, 'p5 '), (0.50, '중앙'), (0.95, 'p95')]:\n    x_val = int(model_data[X_var].quantile(pct))\n    print(f'접속 {x_val:2d}회 ({label}): CATE = {beta_T + beta_TX * x_val:+.1%}')\n\nmodel_data['cate'] = beta_T + beta_TX * model_data[X_var]","key":"q3w4WkdYkj"},{"type":"outputs","id":"RtDQpc2STQJCLWgLr9OJa","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"β₁ (기본 처치 효과): +0.1679\nβ₃ (접속 횟수당 효과 변화): -0.009004\n\n접속  1회 (p5 ): CATE = +15.9%\n접속 14회 (중앙): CATE = +4.2%\n접속 31회 (p95): CATE = -11.1%\n"},"children":[],"key":"sG0lrkpcrL"}],"key":"lDholI2TQ4"}],"key":"yTFXTaDg7q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"x_min = int(model_data[X_var].quantile(0.05))\nx_max = int(model_data[X_var].quantile(0.95))\nx_range = np.arange(x_min, x_max + 1)\ncate_line = beta_T + beta_TX * x_range\n\nfig, axes = plt.subplots(1, 2, figsize=(11, 4))\n\nax = axes[0]\nax.plot(x_range, cate_line, color='#4477AA', linewidth=2)\nax.axhline(ate, color='#888888', linestyle='--', label=f'ATE = {ate:+.1%}')\nax.axhline(0, color='black', linewidth=0.8)\nax.fill_between(x_range, cate_line, 0,\n                where=(cate_line > 0), alpha=0.1, color='#4477AA')\nax.fill_between(x_range, cate_line, 0,\n                where=(cate_line <= 0), alpha=0.1, color='#EE6677')\nax.yaxis.set_major_formatter(mtick.PercentFormatter(1.0))\nax.set_xlabel('접속 횟수 (n_logins)')\nax.set_ylabel('CATE')\nax.set_title('접속 횟수별 처치 효과')\nax.legend()\n\nax = axes[1]\nplot_data = model_data.loc[model_data[X_var] <= x_max, 'cate']\nax.hist(plot_data, bins=30, color='#4477AA', alpha=0.75, edgecolor='white')\nax.axvline(ate, color='#888888', linestyle='--', label=f'ATE = {ate:+.1%}')\nax.axvline(0, color='black', linewidth=0.8)\nax.xaxis.set_major_formatter(mtick.PercentFormatter(1.0))\nax.set_xlabel('CATE')\nax.set_ylabel('유저 수')\nax.set_title('유저별 CATE 분포')\nax.legend()\n\nplt.tight_layout()\nplt.show()","key":"w09rgYA0tV"},{"type":"outputs","id":"904bI4lI5fJlmWG3loZ1Y","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"700cb895ef5a9100551bed238321c817","path":"/causal-inference-kr/build/700cb895ef5a9100551bed238321c817.png"},"text/plain":{"content":"<Figure size 1100x400 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"FW1rD5Re0r"}],"key":"BJI25xFqJZ"}],"key":"gzrEe0BaHv"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"chil